# true = Mock-Login ohne Authentik; false = OIDC (AUTHENTIK_* erforderlich)
DEV=false
# Erlaubte Browser-Origins (kommagetrennt). In NODE_ENV!=production werden zusaetzlich immer localhost:5173/8080 und 127.0.0.1 erlaubt.
FRONTEND_ORIGIN=http://localhost:8080
AUTHENTIK_OIDC_ISSUER=https://auth.example.com/application/o/raumbuchung
AUTHENTIK_OIDC_CLIENT_ID=raumbuchung-frontend
AUTHENTIK_OIDC_AUDIENCE=raumbuchung-frontend
AUTHENTIK_OIDC_APP_ORIGIN=http://localhost:8080
AUTHENTIK_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:8080
AUTHENTIK_OIDC_SCOPE=openid profile email phone
AUTHENTIK_OIDC_USERINFO_URL=https://auth.example.com/application/o/raumbuchung/userinfo/
AUTHENTIK_OIDC_ENABLE_USERINFO_FALLBACK=false
AUTHENTIK_OIDC_JWKS_TIMEOUT_MS=5000
AUTHENTIK_OIDC_CLOCK_TOLERANCE_SEC=0
# Optional: OIDC/Userinfo claim names for profile sync (defaults cover phone_number, PLZ, etc.)
# AUTHENTIK_CLAIM_PHONE=telefonnummer
# AUTHENTIK_CLAIM_POSTAL_CODE=plz
MAIL_ENABLED=false
MAIL_HOST=mail.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USERNAME=mailuser@example.com
MAIL_PASSWORD=change-me
MAIL_FROM="Raumbuchung <noreply@example.com>"
MAIL_APP_URL=http://localhost:8080
# Kommagetrennt: Admin-Benachrichtigung bei neuer Serienbuchung
MAIL_ADMIN_EMAIL=admin@example.com
# --- Frontend (Vite): API-Erreichbarkeit ---
# Volle Basis-URL der REST-API (axios). Beispiele:
#   Mit Reverse-Proxy / gleicher Origin wie das UI:  VITE_API_URL=/api
#   Frontend z. B. :8080, Backend :3000 ohne Proxy:  VITE_API_URL=http://localhost:3000/api
# Nur Backend-Origin (es wird immer /api angehaengt):
#   VITE_BACKEND_ORIGIN=http://localhost:3000
# Hinweis: `npm run dev` laedt .env aus Projektwurzel und aus frontend/ (Werte in frontend/.env ueberschreiben).
VITE_API_URL=/api
# VITE_BACKEND_ORIGIN=http://localhost:3000