PORT=3000
FRONTEND_ORIGIN=http://localhost:8080
DATABASE_URL=postgresql://postgres:postgres@db:5432/raumbuchung
AUTH_MODE=dev
AUTHENTIK_ISSUER=https://auth.example.com/application/o/raumbuchung
AUTHENTIK_AUDIENCE=raumbuchung
AUTHENTIK_JWKS_URL=https://auth.example.com/application/o/raumbuchung/jwks/
AUTHENTIK_USERINFO_URL=https://auth.example.com/application/o/raumbuchung/userinfo/
AUTHENTIK_ENABLE_USERINFO_FALLBACK=true
AUTH_JWKS_TIMEOUT_MS=5000
AUTH_CLOCK_TOLERANCE_SEC=5
MAIL_ENABLED=false
MAIL_HOST=mail.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USERNAME=mailuser@example.com
MAIL_PASSWORD=change-me
MAIL_FROM="Raumbuchung <noreply@example.com>"
MAIL_APP_URL=http://localhost:8080
