    "@capacitor/core": "^8.4.0",
    "@capacitor/preferences": "^8.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.96.2",
    "axios": "^1.14.0",
    "dayjs": "^1.11.20",
    "oidc-client-ts": "^3.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@eslint/js": "^9.39.4",
