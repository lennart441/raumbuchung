{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:mobile": "tsc -b && vite build --mode mobile",
    "cap:sync": "npm run build:mobile && npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:assets": "npx capacitor-assets generate --android --assetPath assets",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
