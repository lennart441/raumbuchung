# Mobile/Android production build: cp .env.mobile.example .env.mobile
# Secrets nur in .env.mobile (gitignored), nie ins Repo committen.
#
# Variante A: VITE_* Werte direkt setzen (empfohlen)
# Variante B: AUTHENTIK_OIDC_* aus der Server-.env kopieren — vite.config.ts mappt sie beim mobile-Build
#
# In Authentik beim bestehenden Provider zusaetzlich eintragen:
#   Redirect URI: de.stocksee.raumbuchung://oauth/callback
#   Post-logout:  de.stocksee.raumbuchung://oauth/logout
#   PKCE + Refresh Tokens aktivieren

VITE_DEV=false
VITE_API_URL=https://raum.stocksee.de/api

VITE_AUTHENTIK_OIDC_ISSUER=https://auth.stocksee.de/application/o/raumbuchung
VITE_AUTHENTIK_OIDC_CLIENT_ID=<aus-authentik-provider-slug-oder-client-id>
VITE_AUTHENTIK_OIDC_APP_ORIGIN=de.stocksee.raumbuchung://oauth/callback
VITE_AUTHENTIK_OIDC_POST_LOGOUT_REDIRECT_URI=de.stocksee.raumbuchung://oauth/logout
VITE_AUTHENTIK_OIDC_SCOPE=openid profile email phone offline_access

# Alternativ Backend-Namen (werden beim `npm run build:mobile` automatisch auf VITE_* gemappt):
# AUTHENTIK_OIDC_ISSUER=https://auth.stocksee.de/application/o/raumbuchung
# AUTHENTIK_OIDC_CLIENT_ID=<client-id>
# AUTHENTIK_OIDC_SCOPE=openid profile email phone offline_access
