# API-Basis: volle URL ODER /api (Vite leitet im Dev-Modus an VITE_BACKEND_ORIGIN weiter, Default http://127.0.0.1:3000)
VITE_API_URL=/api
# Alternative zu VITE_API_URL: nur Origin, Ziel wird .../api
# VITE_BACKEND_ORIGIN=http://localhost:3000
# Fallback, falls /auth/config nicht erreichbar ist (z. B. reines Vite ohne Proxy)
VITE_DEV=false
VITE_AUTHENTIK_OIDC_ISSUER=https://auth.example.com/application/o/raumbuchung
VITE_AUTHENTIK_OIDC_CLIENT_ID=raumbuchung-frontend
VITE_AUTHENTIK_OIDC_APP_ORIGIN=http://localhost:8080
VITE_AUTHENTIK_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:8080
VITE_AUTHENTIK_OIDC_SCOPE=openid profile email phone
