FROM node:22-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
ARG VITE_API_URL=/api
ARG VITE_AUTH_MODE=oidc
ARG VITE_AUTHENTIK_OIDC_ISSUER=
ARG VITE_AUTHENTIK_OIDC_CLIENT_ID=
ARG VITE_AUTHENTIK_OIDC_APP_ORIGIN=
ARG VITE_AUTHENTIK_OIDC_POST_LOGOUT_REDIRECT_URI=
ARG VITE_AUTHENTIK_OIDC_SCOPE=openid profile email phone
ENV VITE_API_URL=${VITE_API_URL}
ENV VITE_AUTH_MODE=${VITE_AUTH_MODE}
ENV VITE_AUTHENTIK_OIDC_ISSUER=${VITE_AUTHENTIK_OIDC_ISSUER}
ENV VITE_AUTHENTIK_OIDC_CLIENT_ID=${VITE_AUTHENTIK_OIDC_CLIENT_ID}
ENV VITE_AUTHENTIK_OIDC_APP_ORIGIN=${VITE_AUTHENTIK_OIDC_APP_ORIGIN}
ENV VITE_AUTHENTIK_OIDC_POST_LOGOUT_REDIRECT_URI=${VITE_AUTHENTIK_OIDC_POST_LOGOUT_REDIRECT_URI}
ENV VITE_AUTHENTIK_OIDC_SCOPE=${VITE_AUTHENTIK_OIDC_SCOPE}
RUN npm run build

FROM nginx:1.27-alpine AS runtime
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
